NODE_ENV=development
PORT=3001
# Comma-separated admin portal origins (local + Vercel). *.vercel.app is also allowed.
ADMIN_PORTAL_URL=http://localhost:5173,https://your-admin.vercel.app

MONGODB_URI=mongodb://localhost:27017/zoomcontrol

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-admin-access-secret-min-64-chars
JWT_CLIENT_SECRET=change-me-client-access-secret-min-64-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-64-chars

SUPER_ADMIN_EMAIL=superadmin@zoomcontrol.local
SUPER_ADMIN_PASSWORD=SuperAdmin123!

# Set ZOOM_MOCK=true to run without real Zoom credentials (dev)
ZOOM_MOCK=true

# Reconciliation (Phase 6)
RECONCILE_ENABLED=true
RECONCILE_INTERVAL_MS=60000

# Zoom — Server-to-Server OAuth App
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_HOST_USER_ID=
# Default Zoom user for admins without a dedicated zoomHostUserId (set per admin in Super Admin → Admins)

# Zoom — Meeting SDK App
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# Zoom — Webhook secret (from Event Subscriptions)
ZOOM_WEBHOOK_SECRET_TOKEN=

# Optional fallback for mock/dev when no live session (instant meetings use MongoDB ActiveMeeting)
ZOOM_MEETING_NUMBER=
ZOOM_MEETING_PASSWORD=

# Public URL for webhook registration (ngrok or production), e.g. https://abc123.ngrok.io
PUBLIC_API_URL=
